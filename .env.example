# Pide Servicio — Variables de entorno requeridas
# Copiar este archivo a .env.local y completar los valores reales.
# NUNCA commitear el archivo .env.local con valores reales.

# ── Supabase ──────────────────────────────────────────────────────────────────
# CLI local: ejecutar `supabase start` y usar los valores de `supabase status`
# Cloud: https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Solo en Edge Functions / servidor (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ── Backend .NET API ──────────────────────────────────────────────────────────
# Puerto definido en backend/src/PideServicio.Api/Properties/launchSettings.json
VITE_API_URL=http://localhost:5000

# ── Cuentas demo (opcional) ───────────────────────────────────────────────────
# Solo si Supabase tiene los usuarios de demostración creados.
VITE_DEMO_SUPERADMIN_EMAIL=superadmin@demo.pideservicio.app
VITE_DEMO_ADMIN_EMAIL=admin@demo.pideservicio.app
VITE_DEMO_TRABAJADOR_EMAIL=trabajador@demo.pideservicio.app
VITE_DEMO_PASSWORD=Demo1234!

# ── Resend (correos transaccionales — solo backend) ───────────────────────────
RESEND_API_KEY=re_tu-api-key

# ── Entorno ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
